---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'

// Photos reelles scrapees depuis emiliepruneta.com (wixstatic CDN, toutes verifiees 200)
const BASE = 'https://static.wixstatic.com/media'
const hero      = `${BASE}/054844_024a583a5c674dab9db20b46fe34f983~mv2.jpg/v1/fill/w_1800,h_1000,fp_0.51_0.24,q_90,enc_avif,quality_auto/ep.jpg`
const img2      = `${BASE}/054844_57106e83d1f84fd3ba946d05be873c45~mv2.jpg/v1/fill/w_900,h_1200,fp_0.66_0.37,q_90,enc_avif,quality_auto/ep.jpg`
const img3      = `${BASE}/054844_b12f64fb940740acaaa0ec88dda41e8d~mv2.jpg/v1/fill/w_900,h_1200,fp_0.47_0.26,q_90,enc_avif,quality_auto/ep.jpg`
const imgBig    = `${BASE}/054844_5f3021aa63c24bc98ad3976e9caace6f~mv2.jpg/v1/fill/w_1600,h_900,fp_0.48_0.37,q_90,enc_avif,quality_auto/ep.jpg`
const imgFam1   = `${BASE}/054844_1f805cd6e6034bfe844fc7cf12acfd25~mv2.jpg/v1/fill/w_700,h_933,fp_0.41_0.22,q_90,enc_avif,quality_auto/ep.jpg`
const imgFam2   = `${BASE}/054844_748b01f672f84c3fae7b06b8c5c1b9ef.jpg/v1/fill/w_700,h_933,al_c,q_90,enc_avif,quality_auto/ep.jpg`
const imgFam3   = `${BASE}/054844_034c92095d0e4db0987dddee5b255cb7~mv2.jpg/v1/fill/w_700,h_933,fp_0.43_0.4,q_90,enc_avif,quality_auto/ep.jpg`
const imgFam4   = `${BASE}/054844_b9f9ae617f36436096bc6c9d2b4103d6~mv2.jpg/v1/fill/w_700,h_933,fp_0.59_0.31,q_90,enc_avif,quality_auto/ep.jpg`
const imgEmilie = `${BASE}/054844_403fa8728ab94f879bae2f087e75077e~mv2.jpg/v1/fill/w_800,h_1067,al_c,q_90,enc_avif,quality_auto/ep.jpg`

const temoignages = [
  {
    texte: "Emilie a su capter chaque regard, chaque sourire, chaque émotion de notre journée. On revit notre mariage à chaque fois qu'on feuillette l'album.",
    auteur: "Marie et Thomas",
    detail: "Mariés en Corrèze, juin 2024"
  },
  {
    texte: "La séance grossesse s'est passée dans un tel naturel. Emilie met vraiment à l'aise, on oublie complètement l'appareil. Les photos sont magnifiques.",
    auteur: "Léa",
    detail: "Séance grossesse, Brive, 2024"
  },
  {
    texte: "Un vrai talent pour saisir les instants de famille. Les enfants ont joué, ri, et Emilie a tout capturé avec une douceur incroyable.",
    auteur: "La famille Mouret",
    detail: "Séance famille, Dordogne, 2023"
  },
]

const etapes = [
  { label: 'Premier échange', titre: 'On se parle', texte: "Par mail ou téléphone, vous me racontez votre projet. Je vous explique comment je travaille. Pas de formulaire à remplir, juste une conversation." },
  { label: 'On se découvre', titre: 'Un café, un appel', texte: "Pour les mariages, je propose qu'on se retrouve, en visio ou autour d'un café. C'est important qu'on soit à l'aise l'un avec l'autre avant le grand jour." },
  { label: 'Le jour J', titre: 'Je suis là', texte: "Discrète, attentive. Je guide quand c'est utile, je m'efface quand l'émotion arrive. Vous vivez votre journée, je fais le reste." },
  { label: 'Votre galerie', titre: 'Les photos arrivent', texte: "Sous 4 à 8 semaines, vous recevez votre galerie privée en ligne. Chaque image est retouchée à la main, dans un style lumineux et naturel." },
]
---
<Layout>
  <Nav />

  <main id="top" class="pt-16">

    <!-- ══════════ HERO ══════════ -->
    <section class="relative min-h-[92vh] sm:min-h-screen flex flex-col overflow-hidden border-b border-line">
      <figure class="absolute inset-0">
        <img src={hero} alt="Mariage photographié par Emilie Pruneta en Corrèze" class="w-full h-full object-cover" loading="eager" fetchpriority="high" style="object-position: center 30%;"/>
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(26,22,18,0.28) 0%, rgba(26,22,18,0.52) 100%);"></div>
      </figure>

      <div class="relative flex-1 flex flex-col justify-end max-w-[1280px] mx-auto px-5 sm:px-8 pb-16 sm:pb-20 w-full">
        <div class="hero-item mb-5 flex items-center gap-3" style="--hi:0">
          <span class="dot" style="background:#faf8f5; opacity:0.6;"></span>
          <span class="eyebrow" style="color: rgba(250,248,245,0.6);">Photographe · Corrèze · Depuis 2012</span>
        </div>

        <h1 class="hero-item font-display italic font-light leading-[1.0] max-w-3xl" style="--hi:1; font-size: var(--text-display-xl); color: var(--color-fg-inv);">
          Ce que vous vivez,<br/>je le garde<br/><em style="font-style:normal; font-weight:300; opacity:0.75;">pour vous.</em>
        </h1>

        <p class="hero-item mt-6 max-w-md text-base font-light leading-relaxed" style="--hi:2; color: rgba(250,248,245,0.72);">
          Mariage, famille, grossesse, nouveau-né. Je photographie vos plus belles émotions avec discrétion et sensibilité, en Corrèze et alentours.
        </p>

        <div class="hero-item mt-10 flex flex-wrap gap-3" style="--hi:3">
          <a href="#contact" class="cta" style="background:var(--color-fg-inv); color:var(--color-fg);">Demander un devis <span aria-hidden="true">→</span></a>
          <a href="#mariages" class="cta-ghost" style="border-color:rgba(250,248,245,0.4); color:var(--color-fg-inv);">Voir le travail</a>
        </div>
      </div>
    </section>

    <!-- ══════════ INTRO EMILIE ══════════ -->
    <section id="apropos" class="border-b border-line">
      <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-20 sm:py-28 grid lg:grid-cols-12 gap-12 items-center reveal-on-scroll">
        <div class="lg:col-span-5">
          <figure class="aspect-[4/5] overflow-hidden" style="background: var(--color-bg-elev);">
            <img src={imgEmilie} alt="Emilie Pruneta, photographe" class="w-full h-full object-cover" loading="lazy"/>
          </figure>
        </div>
        <div class="lg:col-span-6 lg:col-start-7">
          <p class="eyebrow mb-5">À propos</p>
          <h2 class="font-display italic font-light leading-[1.1] mb-8" style="font-size: var(--text-h2);">
            Je vibre à vos côtés<br/><em style="font-style:normal; color:var(--color-muted-strong);">dans vos grands moments.</em>
          </h2>
          <div class="space-y-5 text-base leading-relaxed" style="color: var(--color-muted-strong);">
            <p>
              Je m'appelle Emilie. Je photographie des mariages, des familles et des naissances en Corrèze depuis 2012. Ce que j'aime dans ce métier, c'est ce qui ne se commande pas : un regard, une main qui serre l'autre, un rire qui éclate au mauvais moment.
            </p>
            <p>
              Je travaille en retrait, sans diriger. J'observe, j'attends, je déclenche quand ça arrive vraiment. Pas de poses répétées, pas de mise en scène. Juste ce qui s'est passé.
            </p>
            <p>
              En 12 ans, j'ai photographié des centaines de familles et de couples. Chaque fois, les gens me disent la même chose : ils avaient oublié que j'étais là.
            </p>
          </div>
          <a href="#contact" class="mt-10 inline-flex items-center gap-2 text-sm font-medium" style="color:var(--color-accent);">
            Me contacter <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ══════════ PRESTATIONS MARIAGE ══════════ -->
    <section id="mariages" class="border-b border-line" style="background: var(--color-bg-elev);">
      <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-20 sm:py-28 reveal-on-scroll">
        <div class="grid lg:grid-cols-12 gap-10 mb-14">
          <div class="lg:col-span-5">
            <p class="eyebrow mb-4">Mariage</p>
            <h2 class="font-display italic font-light leading-[1.1]" style="font-size: var(--text-h2);">
              Votre histoire,<br/><em style="font-style:normal;">racontée en images.</em>
            </h2>
          </div>
          <div class="lg:col-span-6 lg:col-start-7 flex items-end">
            <p class="text-base leading-relaxed" style="color: var(--color-muted-strong);">
              Des préparatifs jusqu'à la fête, je suis là pour tout capter : les regards, les silences, les éclats de joie. Un reportage discret et sensible, qui vous ressemble.
            </p>
          </div>
        </div>

        <!-- Galerie mariage asymétrique -->
        <div class="grid grid-cols-12 gap-2 sm:gap-3">
          <figure class="col-span-8 aspect-[4/3] overflow-hidden">
            <img src={hero} alt="Couple de mariés photographiés par Emilie Pruneta" class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700" loading="lazy"/>
          </figure>
          <figure class="col-span-4 aspect-[3/4] overflow-hidden">
            <img src={img2} alt="Détails de mariage, reportage Emilie Pruneta" class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700" loading="lazy"/>
          </figure>
          <figure class="col-span-4 aspect-[3/4] overflow-hidden">
            <img src={img3} alt="Portraits mariés, Corrèze" class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700" loading="lazy"/>
          </figure>
          <figure class="col-span-8 aspect-[4/3] overflow-hidden">
            <img src={img2} alt="Cérémonie de mariage en plein air" class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700" loading="lazy" style="object-position: center 20%;"/>
          </figure>
        </div>

        <div class="mt-10 flex justify-center">
          <a href="#contact" class="cta">Réserver votre date <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <!-- ══════════ PHOTO BREAK ══════════ -->
    <div class="relative aspect-[21/8] overflow-hidden border-b border-line">
      <img src={imgBig} alt="Emilie Pruneta, photographe de mariage en Corrèze" class="w-full h-full object-cover" loading="lazy" style="object-position: center 35%;"/>
      <div class="absolute inset-0" style="background: rgba(26,22,18,0.45);"></div>
      <div class="absolute inset-0 flex items-center justify-center text-center px-6">
        <blockquote class="font-display italic font-light max-w-2xl" style="font-size: clamp(1.8rem, 4vw, 3.5rem); color: var(--color-fg-inv); line-height: 1.2;">
          "Je capte ce que vous vivez,<br/>pas ce que vous jouez."
        </blockquote>
      </div>
    </div>

    <!-- ══════════ FAMILLE / GROSSESSE / NAISSANCE ══════════ -->
    <section id="famille" class="border-b border-line">
      <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-20 sm:py-28 reveal-on-scroll">
        <p class="eyebrow mb-4">Famille · Grossesse · Nouveau-né</p>
        <h2 class="font-display italic font-light leading-[1.1] mb-12 max-w-2xl" style="font-size: var(--text-h2);">
          Les premiers regards,<br/><em style="font-style:normal; color:var(--color-muted-strong);">les souvenirs qui durent.</em>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3">
          <figure class="aspect-[3/4] overflow-hidden">
            <img src={imgFam1} alt="Séance famille en extérieur" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700" loading="lazy"/>
          </figure>
          <figure class="aspect-[3/4] overflow-hidden sm:mt-10">
            <img src={imgFam2} alt="Séance grossesse, lumière naturelle" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700" loading="lazy"/>
          </figure>
          <figure class="aspect-[3/4] overflow-hidden">
            <img src={imgFam3} alt="Portrait nouveau-né, Corrèze" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700" loading="lazy"/>
          </figure>
          <figure class="aspect-[3/4] overflow-hidden sm:mt-10">
            <img src={imgFam4} alt="Famille, séance photo naturelle" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700" loading="lazy"/>
          </figure>
        </div>

        <div class="mt-14 grid sm:grid-cols-3 gap-px border-y border-line" style="background: var(--color-line);">
          {[
            { titre: 'Famille', texte: 'Enfants qui courent, câlins improvisés, éclats de rire. Je capture votre famille telle qu\'elle est vraiment.' },
            { titre: 'Grossesse', texte: 'Le ventre rond, la lumière du matin. Une séance dehors ou chez vous, à quelques semaines de l\'arrivée.' },
            { titre: 'Nouveau-né', texte: 'À domicile, dans les premiers jours. On prend le temps, sans brusquer ni mettre en scène.' },
          ].map((p) => (
            <div class="py-10 px-8" style="background: var(--color-bg);">
              <h3 class="font-display italic text-2xl mb-3">{p.titre}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-muted-strong);">{p.texte}</p>
            </div>
          ))}
        </div>

        <div class="mt-10 flex justify-center">
          <a href="#contact" class="cta">Réserver une séance <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <!-- ══════════ TEMOIGNAGES ══════════ -->
    <section class="border-b border-line" style="background: var(--color-bg-elev);">
      <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-20 sm:py-28 reveal-on-scroll">
        <p class="eyebrow mb-12 text-center">Ce qu'ils en disent</p>
        <div class="grid sm:grid-cols-3 gap-px" style="background: var(--color-line);">
          {temoignages.map((t) => (
            <blockquote class="p-8 sm:p-10" style="background: var(--color-bg);">
              <p class="font-display italic text-xl sm:text-2xl font-light leading-relaxed mb-8" style="color: var(--color-muted-strong);">
                "{t.texte}"
              </p>
              <footer>
                <p class="font-medium text-sm">{t.auteur}</p>
                <p class="text-xs mt-1" style="color: var(--color-muted);">{t.detail}</p>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════ COMMENT CA SE PASSE ══════════ -->
    <section class="border-b border-line">
      <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-20 sm:py-28 reveal-on-scroll">
        <p class="eyebrow mb-4">Le déroulement</p>
        <h2 class="font-display italic font-light leading-[1.1] mb-14" style="font-size: var(--text-h2);">
          Comment ça<br/><em style="font-style:normal; color:var(--color-muted-strong);">se passe.</em>
        </h2>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px border-y border-line" style="background: var(--color-line);">
          {etapes.map((e) => (
            <div class="py-10 px-8" style="background: var(--color-bg);">
              <p class="eyebrow mb-5" style="color: var(--color-accent);">{e.label}</p>
              <h3 class="font-display italic text-xl mb-3">{e.titre}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-muted-strong);">{e.texte}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════ CONTACT / CTA FINAL ══════════ -->
    <section id="contact" class="relative overflow-hidden border-b border-line" style="background: var(--color-bg-dark);">
      <div class="absolute pointer-events-none" style="inset:0; background: radial-gradient(ellipse at 60% 50%, rgba(196,129,106,0.12) 0%, transparent 70%);" aria-hidden="true"></div>

      <div class="relative max-w-[1280px] mx-auto px-5 sm:px-8 py-24 sm:py-32 reveal-on-scroll">
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-5">
            <p class="eyebrow mb-5" style="color: rgba(250,248,245,0.45);">Contact</p>
            <h2 class="font-display italic font-light leading-[1.1] mb-6" style="font-size: var(--text-h2); color: var(--color-fg-inv);">
              Un projet ?<br/><em style="font-style:normal; color: var(--color-accent);">Écrivez-moi.</em>
            </h2>
            <p class="text-base leading-relaxed mb-10" style="color: rgba(250,248,245,0.60);">
              Mariage, famille, grossesse, naissance. Dites-moi la date, le lieu, ce que vous avez en tête. Je réponds sous 48h.
            </p>
            <div class="space-y-3">
              <a href="mailto:emilie@emiliepruneta.com" class="flex items-center gap-3 text-sm transition-colors" style="color: rgba(250,248,245,0.70);">
                <span style="color: var(--color-accent);">→</span> emilie@emiliepruneta.com
              </a>
              <p class="text-sm" style="color: rgba(250,248,245,0.45);">Zone : Corrèze · Lot · Dordogne · France entière pour les mariages</p>
            </div>
          </div>

          <div class="lg:col-span-6 lg:col-start-7">
            <form class="space-y-5" name="contact" method="POST" data-netlify="true" action="/">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs mb-2" style="color: rgba(250,248,245,0.45); letter-spacing:0.1em; text-transform:uppercase;">Prénom</label>
                  <input type="text" name="prenom" required class="w-full px-4 py-3 text-sm outline-none focus:ring-1 transition-all" style="background: rgba(250,248,245,0.06); border: 1px solid rgba(250,248,245,0.14); color: var(--color-fg-inv); border-radius: 1px;" placeholder="Votre prénom"/>
                </div>
                <div>
                  <label class="block text-xs mb-2" style="color: rgba(250,248,245,0.45); letter-spacing:0.1em; text-transform:uppercase;">Email</label>
                  <input type="email" name="email" required class="w-full px-4 py-3 text-sm outline-none transition-all" style="background: rgba(250,248,245,0.06); border: 1px solid rgba(250,248,245,0.14); color: var(--color-fg-inv); border-radius: 1px;" placeholder="votre@email.fr"/>
                </div>
              </div>

              <div>
                <label class="block text-xs mb-2" style="color: rgba(250,248,245,0.45); letter-spacing:0.1em; text-transform:uppercase;">Type de projet</label>
                <select name="projet" class="w-full px-4 py-3 text-sm outline-none transition-all" style="background: rgba(250,248,245,0.06); border: 1px solid rgba(250,248,245,0.14); color: var(--color-fg-inv); border-radius: 1px;">
                  <option value="" style="background:#1a1612;">Choisir...</option>
                  <option value="mariage" style="background:#1a1612;">Mariage</option>
                  <option value="famille" style="background:#1a1612;">Famille</option>
                  <option value="grossesse" style="background:#1a1612;">Grossesse</option>
                  <option value="naissance" style="background:#1a1612;">Nouveau-né</option>
                </select>
              </div>

              <div>
                <label class="block text-xs mb-2" style="color: rgba(250,248,245,0.45); letter-spacing:0.1em; text-transform:uppercase;">Votre message</label>
                <textarea name="message" rows="4" class="w-full px-4 py-3 text-sm outline-none resize-none transition-all" style="background: rgba(250,248,245,0.06); border: 1px solid rgba(250,248,245,0.14); color: var(--color-fg-inv); border-radius: 1px;" placeholder="Parlez-moi de votre projet, votre date, votre lieu..."></textarea>
              </div>

              <button type="submit" class="w-full py-4 text-sm font-medium tracking-widest uppercase transition-all" style="background: var(--color-accent); color: #fff; border-radius: 1px; letter-spacing: 0.15em;">
                Envoyer ma demande
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
