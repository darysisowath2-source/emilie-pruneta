---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Emilie Pruneta · Photographe mariage et famille en Corrèze',
  description = "Photographe de mariage, famille, grossesse et nouveau-né en Corrèze et alentours. Reportages naturels et émotionnels depuis 2012.",
} = Astro.props

const SITE = (Astro.site?.href || 'https://emilie-pruneta.pages.dev/').replace(/\/$/, '')
const ogImage = 'https://static.wixstatic.com/media/054844_ea8fc02bdcbb4ae797f76da85ffe839c~mv2.jpg/v1/fill/w_1200,h_630,fp_0.5_0.4,q_90,enc_avif,quality_auto/ep.jpg'
const canonical = SITE + Astro.url.pathname
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#faf8f5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Photographer",
      "name": "Emilie Pruneta",
      "image": ogImage,
      "url": SITE,
      "description": description,
      "areaServed": ["Corrèze", "Lot", "Dordogne"],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Brive-la-Gaillarde",
        "postalCode": "19100",
        "addressCountry": "FR"
      }
    })} />
  </head>
  <body class="bg-bg text-fg antialiased">
    <slot />

    <script>
      const revealSingle = document.querySelectorAll('.reveal-on-scroll');
      const revealChildren = document.querySelectorAll('.reveal-children > *');
      revealChildren.forEach((el) => el.classList.add('reveal-child'));
      const allTargets = [...revealSingle, ...revealChildren];
      if ('IntersectionObserver' in window && allTargets.length) {
        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        }, { rootMargin: '0px 0px -6% 0px', threshold: 0.04 });
        allTargets.forEach((el) => io.observe(el));
      } else {
        allTargets.forEach((el) => el.classList.add('is-visible'));
      }
    </script>

    <script>
      // Formulaire de contact -> ouvre la messagerie pré-remplie (mailto)
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const prenom = (data.get('prenom') || '').toString();
        const email = (data.get('email') || '').toString();
        const projet = (data.get('projet') || '').toString();
        const message = (data.get('message') || '').toString();
        const sujet = `Demande ${projet ? '· ' + projet : 'de contact'} — ${prenom}`;
        const corps = `Bonjour Emilie,\n\n${message}\n\n— ${prenom}\nEmail : ${email}\nProjet : ${projet || 'non précisé'}`;
        window.location.href = `mailto:emilie@emiliepruneta.com?subject=${encodeURIComponent(sujet)}&body=${encodeURIComponent(corps)}`;
      });
    </script>

    <script>
      import Lenis from 'lenis'
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      })
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault()
          const id = (anchor as HTMLAnchorElement).getAttribute('href')
          if (id) lenis.scrollTo(id, { offset: -72 })
        })
      })
      function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf) }
      requestAnimationFrame(raf)
    </script>
  </body>
</html>
